{
  "name": "@glotblocks/glost-utils",
  "version": "0.3.8",
  "description": "Framework-agnostic utilities for GLOST manipulation, conversion, and merging",
  "author": "fustilio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fustilio/glost.git",
    "directory": "packages/utils"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./text-to-glost": {
      "types": "./dist/text-to-glost.d.ts",
      "default": "./dist/text-to-glost.js"
    },
    "./merger": {
      "types": "./dist/glost-merger.d.ts",
      "default": "./dist/glost-merger.js"
    },
    "./document": {
      "types": "./dist/document-utils.d.ts",
      "default": "./dist/document-utils.js"
    },
    "./script": {
      "types": "./dist/script-conversion.d.ts",
      "default": "./dist/script-conversion.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces.d.ts",
      "default": "./dist/interfaces.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    }
  },
  "dependencies": {
    "@glotblocks/glost": "workspace:*",
    "@glotblocks/glost-common": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  },
  "keywords": [
    "glost",
    "multilingual",
    "utilities",
    "text-conversion",
    "document-manipulation"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest --passWithNoTests",
    "lint": "echo 'No linting configured'",
    "prepublishOnly": "npm run build && publint"
  },
  "publishConfig": {
    "access": "public"
  }
}
