{
  "name": "@glotblocks/glost-clause-segmenter",
  "version": "0.2.10",
  "description": "Clause segmentation extension for GLOST - segments sentences into clauses",
  "author": "GLOST Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fustilio/glost.git",
    "directory": "packages/plugins/clause-segmenter"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
