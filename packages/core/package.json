{
  "name": "@glotblocks/glost-core",
  "version": "0.6.2",
  "description": "Core types, nodes, and utilities for GLOST (Glossed Syntax Tree)",
  "author": "fustilio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fustilio/glost.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "glost": "./dist/cli/migrate.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nodes": {
      "types": "./dist/nodes.d.ts",
      "default": "./dist/nodes.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    },
    "./validators": {
      "types": "./dist/validators.d.ts",
      "default": "./dist/validators.js"
    },
    "./guards": {
      "types": "./dist/guards.d.ts",
      "default": "./dist/guards.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "unist-util-filter": "^5.0.1",
    "unist-util-find": "^3.0.0",
    "unist-util-flatmap": "^1.0.0",
    "unist-util-is": "^6.0.0",
    "unist-util-map": "^4.0.0",
    "unist-util-modify-children": "^4.0.0",
    "unist-util-remove": "^4.0.0",
    "unist-util-select": "^5.1.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.23.8",
    "@glotblocks/glost-common": "workspace:*"
  },
  "devDependencies": {
    "@types/nlcst": "^2.0.3",
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  },
  "keywords": [
    "glost",
    "glossed-syntax-tree",
    "nlcst",
    "multilingual",
    "language-learning",
    "linguistics",
    "syntax-tree",
    "unist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest --passWithNoTests"
  },
  "publishConfig": {
    "access": "public"
  }
}
