{
  "name": "@glotblocks/glost-common",
  "version": "0.4.2",
  "description": "Common utilities and language configs for GLOST",
  "author": "fustilio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fustilio/glost.git",
    "directory": "packages/common"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./languages": {
      "types": "./dist/languages/index.d.ts",
      "default": "./dist/languages/index.js"
    },
    "./utils/array": {
      "types": "./dist/utils/array.d.ts",
      "default": "./dist/utils/array.js"
    },
    "./utils/groupBy": {
      "types": "./dist/utils/groupBy.d.ts",
      "default": "./dist/utils/groupBy.js"
    },
    "./utils/string": {
      "types": "./dist/utils/string-utils.d.ts",
      "default": "./dist/utils/string-utils.js"
    },
    "./utils/zod": {
      "types": "./dist/utils/zod.d.ts",
      "default": "./dist/utils/zod.js"
    }
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  },
  "keywords": [
    "glost",
    "languages",
    "utilities",
    "i18n",
    "multilingual"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "echo 'No linting configured'",
    "prepublishOnly": "npm run build && publint"
  },
  "publishConfig": {
    "access": "public"
  }
}
