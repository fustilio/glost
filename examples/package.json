{
  "name": "glost-examples",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Examples and demos demonstrating GLOST features",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:demos": "pnpm --filter './demos/**' test",
    "test:webapps": "pnpm --filter './web-apps/**' test",
    "test:benchmarks": "pnpm --filter './benchmarks/**' test",
    "bench": "vitest bench"
  },
  "dependencies": {
    "glost": "workspace:*",
    "glost-core": "workspace:*",
    "glost-plugins": "workspace:*",
    "glost-processor": "workspace:*",
    "glost-registry": "workspace:*",
    "glost-presets": "workspace:*",
    "glost-transcription": "workspace:*",
    "glost-th": "workspace:*",
    "glost-ja": "workspace:*",
    "glost-ko": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@vitejs/plugin-react": "^4.2.1",
    "jsdom": "^23.0.1",
    "react": "^18.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.5"
  }
}
