{
  "name": "@glost/workspace",
  "version": "0.1.0",
  "private": true,
  "description": "GLOST - Glossed Syntax Tree for language learning",
  "license": "MIT",
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test -- --watch",
    "bench": "pnpm -r --no-bail bench",
    "bench:extensions": "pnpm --filter @glotblocks/glost-extensions bench",
    "bench:plugins": "pnpm --filter @glotblocks/glost-plugins bench",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "lint:publish": "pnpm --filter \"./packages/**\" exec publint",
    "changeset:release": "pnpm lint:publish && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^20.0.0",
    "prettier": "^3.5.3",
    "publint": "^0.3.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  },
  "keywords": [
    "glost",
    "glossed-syntax-tree",
    "nlcst",
    "language-learning",
    "multilingual",
    "annotations",
    "syntax-tree"
  ]
}
